# ── Predicta — variáveis de ambiente ──────────────────────────────────────────
# Copie este arquivo para `.env` e preencha. O `.env` está no .gitignore e NUNCA
# deve ser versionado. A chave é usada apenas no servidor (proxy /api/assistant);
# ela não é exposta ao navegador.

# Chave da API da OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Modelo a usar (opcional). Padrão: gpt-4o.
# Alternativas: gpt-4o-mini (mais barato), gpt-4.1, etc. — qualquer modelo de chat
# da OpenAI que suporte function calling + streaming.
OPENAI_MODEL=gpt-4o

# Modelo de VISÃO para leitura de plaquetas (OCR via /api/vision-ocr). Opcional.
# Padrão: gpt-4o. Precisa ser um modelo com visão. Se não houver chave, o OCR cai
# automaticamente no Tesseract.js (client-side).
OPENAI_VISION_MODEL=gpt-4o

# ── RAG / Base técnica (manuais WEG) ──────────────────────────────────────────
# Subsistema Supabase (pgvector + Edge Function assistant-rag). Veja ingestion/README.md.
#
# CLIENTE (expostos ao navegador — apenas URL pública + anon key, NUNCA o service role):
VITE_SUPABASE_URL=https://SEU-PROJ.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# SERVIDOR / INGESTÃO (NUNCA versionar; usados pela Edge Function e pelo pipeline Python):
SUPABASE_URL=https://SEU-PROJ.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...     # secret — só no servidor/CLI
# Defina também como secrets da função:  supabase secrets set OPENAI_API_KEY=... COHERE_API_KEY=...
COHERE_API_KEY=                              # opcional (rerank); sem ela cai no RRF
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536                    # mantenha == vector(1536) no schema
RERANK_MODEL=rerank-multilingual-v3.0
GEN_MODEL=gpt-4o
TOP_K=7
